# Kopier til .env.local og fyll inn verdier
# Supabase – Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend – https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=

# Betaling (Vipps + bankkonto vises på siden)
NEXT_PUBLIC_VIPPS_NUMBER=
NEXT_PUBLIC_ACCOUNT_NUMBER=

# Pris for å leie hallen (1 time), heltall kr. 0 = ingen pris vises.
NEXT_PUBLIC_LEIE_PRIS=250

# Brukes til absolutte lenker i e-post o.l.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
